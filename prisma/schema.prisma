generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum EmployerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
  NEEDS_MORE_DETAILS
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum NoticePeriod {
  IMMEDIATE
  TWO_WEEKS
  ONE_MONTH
  TWO_MONTHS
  THREE_MONTHS
  NEGOTIABLE
}

enum PrivacyCompanyMode {
  EXACT
  MASKED
  INDUSTRY_ONLY
}
model User {
id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("candidate")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  candidateProfile CandidateProfile?
  employerProfile  EmployerProfile?
}

model CandidateProfile {
  id                   String           @id @default(cuid())
  userId               String           @unique
  anonymousId          String           @unique
  fullName             String?
  headline             String?
  summary              String?
  yearsOfExperience    Int              @default(0)
  industryBackground   String?
  salaryExpectationMin Int?
  salaryExpectationMax Int?
  preferredLocation    String?
  workMode             WorkMode         @default(FLEXIBLE)
  noticePeriod         NoticePeriod     @default(NEGOTIABLE)
  isSearchable         Boolean          @default(true)
  profileCompleteness  Int              @default(0)
  searchVisibility     Boolean          @default(true)
  lastActiveAt         DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume               Resume?
  skills               Skill[]
  workExperience       WorkExperience[]
  education            Education[]
  certifications       Certification[]
  privacySetting       PrivacySetting?
  receivedRequests     ContactRequest[] @relation("CandidateRequests")
  savedByEmployers     SavedCandidate[]
  blockedEmployers     BlockedEmployer[]
}

model EmployerProfile {
  id                 String                     @id @default(cuid())
  userId             String                     @unique
  fullName           String
  designation        String
  workEmail          String
  verificationStatus EmployerVerificationStatus @default(PENDING)
  website            String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId          String
  company            Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sentRequests       ContactRequest[]           @relation("EmployerRequests")
  savedCandidates    SavedCandidate[]
  savedSearches      SavedSearch[]
}

model Company {
  id              String            @id @default(cuid())
  name            String
  website         String?
  domain          String?           @unique
  verificationDoc String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  employers       EmployerProfile[]
}

model Resume {
  id                 String           @id @default(cuid())
  candidateProfileId String           @unique
  fileName           String
  fileUrl            String
  mimeType           String
  parsedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model Skill {
  id                 String           @id @default(cuid())
  candidateProfileId String
  name               String
  years              Int?
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model WorkExperience {
  id                 String             @id @default(cuid())
  candidateProfileId String
  title              String
  companyName        String
  industry           String?
  location           String?
  startDate          DateTime?
  endDate            DateTime?
  isCurrent          Boolean            @default(false)
  description        String?
  companyMode        PrivacyCompanyMode @default(MASKED)
  candidateProfile   CandidateProfile   @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model Education {
  id                 String           @id @default(cuid())
  candidateProfileId String
  institution        String
  degree             String
  fieldOfStudy       String?
  graduationYear     Int?
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model Certification {
  id                 String           @id @default(cuid())
  candidateProfileId String
  name               String
  issuer             String?
  year               Int?
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model PrivacySetting {
  id                         String             @id @default(cuid())
  candidateProfileId         String             @unique
  searchable                 Boolean            @default(true)
  showExactCity              Boolean            @default(false)
  companyMode                PrivacyCompanyMode @default(MASKED)
  revealEducationInstitution Boolean            @default(false)
  revealGraduationYear       Boolean            @default(false)
  allowMessagingOnly         Boolean            @default(true)
  candidateProfile           CandidateProfile   @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id                    String               @id @default(cuid())
  candidateProfileId    String
  employerProfileId     String
  jobTitle              String
  message               String
  reason                String
  status                ContactRequestStatus @default(PENDING)
  secureChannelEnabled  Boolean              @default(true)
  revealContactOnAccept Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  candidateProfile      CandidateProfile     @relation("CandidateRequests", fields: [candidateProfileId], references: [id], onDelete: Cascade)
  employerProfile       EmployerProfile      @relation("EmployerRequests", fields: [employerProfileId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedCandidate {
  id                 String           @id @default(cuid())
  employerProfileId  String
  candidateProfileId String
  createdAt          DateTime         @default(now())
  employerProfile    EmployerProfile  @relation(fields: [employerProfileId], references: [id], onDelete: Cascade)
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@unique([employerProfileId, candidateProfileId])
}

model SavedSearch {
  id                String          @id @default(cuid())
  employerProfileId String
  name              String
  query             Json
  createdAt         DateTime        @default(now())
  employerProfile   EmployerProfile @relation(fields: [employerProfileId], references: [id], onDelete: Cascade)
}

model BlockedEmployer {
  id                 String           @id @default(cuid())
  candidateProfileId String
  employerDomain     String
  createdAt          DateTime         @default(now())
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}
model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}